# Example Terraform variables for the digital wallet Azure infrastructure
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored to prevent leaking secrets.

resource_prefix               = "digitalwallet"
resource_group_name           = "digital-wallet-rg"
location                      = "eastus"
frontend_index_document       = "index.html"
frontend_error_document       = "index.html"
backend_port                  = 8080

# Optional additional tags
# tags = {
#   owner        = "team@example.com"
#   cost-center  = "12345"
#   environment  = "development"
# }
