# Terraform local state and provider binaries
.terraform/
# .terraform.lock.hcl is committed for reproducible provider versions
terraform.tfstate
terraform.tfstate.*
*.tfstate
*.tfstate.*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Crash files
crash.log
crash.*.log

# Exclude override files, as they are often used to override resources locally and so are
# ignored in VCS.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Plan files
*.tfplan

# Sensitive variable files
terraform.tfvars
*.auto.tfvars
